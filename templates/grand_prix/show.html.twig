{% extends 'base.html.twig' %}

{% block title %}GrandPrix{% endblock %}

{% block body %}
<h1>GrandPrix</h1>

<table class="table">
    <tbody>
        <tr>
            <th>Id</th>
            <td>{{ grand_prix.id }}</td>
        </tr>
        <tr>
            <th>DateDebut</th>
            <td>{{ grand_prix.dateDebut }}</td>
        </tr>
        <tr>
            <th>HeureDebut</th>
            <td>{{ grand_prix.heureDebut }}</td>
        </tr>
        <tr>
            <th>HeureFin</th>
            <td>{{ grand_prix.heureFin }}</td>
        </tr>
    </tbody>
</table>
<div class="action-buttons">
    <a class="btn-back" href="{{ path('app_grand_prix_index') }}">← Back to list</a>
    {% if is_granted('ROLE_ADMIN') %}
    <a class="btn-edit" href="{{ path('app_grand_prix_edit', {'id': grand_prix.id}) }}">Edit</a>
    {{ include('grand_prix/_delete_form.html.twig') }}
    {% endif %}
</div>
{% endblock %}