{% extends 'base.html.twig' %}

{% block title %}Participant{% endblock %}

{% block body %}
<h1>Participant</h1>

<table class="table">
    <tbody>
        <tr>
            <th>Id</th>
            <td>{{ participant.id }}</td>
        </tr>
    </tbody>
</table>

<div class="action-buttons">
    <a class="btn-back" href="{{ path('app_participant_index') }}">← Back to list</a>
    {% if is_granted('ROLE_ADMIN') %}
    <a class="btn-edit" href="{{ path('app_participant_edit', {'id': participant.id}) }}">Edit</a>
    {{ include('participant/_delete_form.html.twig') }}
    {% endif %}
</div>
{% endblock %}