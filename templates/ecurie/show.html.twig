{% extends 'base.html.twig' %}
{% block title %}Ecurie{% endblock %}
{% block body %}
<h1>Ecurie</h1>
<table class="table">
    <tbody>
        <tr>
            <th>Id</th>
            <td>{{ ecurie.id }}</td>
        </tr>
        <tr>
            <th>NomEcurie</th>
            <td>{{ ecurie.nomEcurie }}</td>
        </tr>
        <tr>
            <th>Logo</th>
            <td>
                {% if ecurie.logo %}
                <img src="{{ asset('web/img/logoEcurie/' ~ ecurie.logo) }}" alt="{{ ecurie.nomEcurie }}">
                {% else %}
                <div class="no-img">NO DATA</div>
                {% endif %}
            </td>
        </tr>
        <tr>
            <th>NbTitreEcurie</th>
            <td>{{ ecurie.nbTitreEcurie }}</td>
        </tr>
    </tbody>
</table>
<div class="action-buttons">
    <a class="btn-back" href="{{ path('app_ecurie_index') }}">← Back to list</a>
    {% if is_granted('ROLE_ADMIN') %}
    <a class="btn-edit" href="{{ path('app_ecurie_edit', {'id': ecurie.id}) }}">Edit</a>
    {{ include('ecurie/_delete_form.html.twig') }}
    {% endif %}
</div>
{% endblock %}