{% extends 'base.html.twig' %}
{% block title %}Pilote{% endblock %}
{% block body %}
<h1>Pilote</h1>
<table class="table">
    <tbody>
        <tr>
            <th>Id</th>
            <td>{{ pilote.id }}</td>
        </tr>
        <tr>
            <th>NomPilote</th>
            <td>{{ pilote.nomPilote }}</td>
        </tr>
        <tr>
            <th>PrenomPilote</th>
            <td>{{ pilote.prenomPilote }}</td>
        </tr>
        <tr>
            <th>Age</th>
            <td>{{ pilote.age }}</td>
        </tr>
        <tr>
            <th>NbTitrePilote</th>
            <td>{{ pilote.nbTitrePilote }}</td>
        </tr>
        <tr>
            <th>Écurie</th>
            <td>
                {% if pilote.ecurie %}
                {{ pilote.ecurie.nomEcurie }}
                {% else %}
                Aucune écurie
                {% endif %}
            </td>
        </tr>
        <tr>
            <th>ImgPilote</th>
            <td>
                {% if pilote.imgPilote %}
                <img src="{{ asset('web/img/imgPilote/' ~ pilote.imgPilote) }}"
                    alt="{{ pilote.prenomPilote }} {{ pilote.nomPilote }}">
                {% else %}
                <div class="no-img">NO DATA</div>
                {% endif %}
            </td>
        </tr>
    </tbody>
</table>

<div class="action-buttons">
    <a class="btn-back" href="{{ path('app_pilote_index') }}">← Back to list</a>
    {% if is_granted('ROLE_ADMIN') %}
    <a class="btn-edit" href="{{ path('app_pilote_edit', {'id': pilote.id}) }}">Edit</a>
    {{ include('pilote/_delete_form.html.twig') }}
    {% endif %}
</div>
{% endblock %}