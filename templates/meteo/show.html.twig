{% extends 'base.html.twig' %}

{% block title %}Meteo{% endblock %}

{% block body %}
<h1>Meteo</h1>

<table class="table">
    <tbody>
        <tr>
            <th>Id</th>
            <td>{{ meteo.id }}</td>
        </tr>
        <tr>
            <th>nomMeteo</th>
            <td>{{ meteo.nomMeteo }}</td>
        </tr>
    </tbody>
</table>

<div class="action-buttons">
    <a class="btn-back" href="{{ path('app_meteo_index') }}">← Back to list</a>
    {% if is_granted('ROLE_ADMIN') %}
    <a class="btn-edit" href="{{ path('app_meteo_edit', {'id': meteo.id}) }}">Edit</a>
    {{ include('meteo/_delete_form.html.twig') }}
    {% endif %}
</div>
{% endblock %}