{% extends 'base.html.twig' %}
{% block title %}Meteo{% endblock %}
{% block body %}
<h1>Meteo</h1>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nom de la météo</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for meteo in meteos %}
        <tr>
            <td>{{ meteo.id }}</td>
            <td>{{ meteo.nomMeteo }}</td>
            <td>
                <a href="{{ path('app_meteo_show', {'id': meteo.id}) }}">show</a>
                {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_meteo_edit', {'id': meteo.id}) }}">edit</a>
                {% endif %}
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="5">no records found</td>
        </tr>
        {% endfor %}

    </tbody>
</table>

{% if is_granted('ROLE_ADMIN') %}
    <a class="btn-create" href="{{ path('app_meteo_new') }}">+ New Meteo</a>
{% endif %}
{% endblock %}