{% extends 'base.html.twig' %}
{% block title %}Voitures{% endblock %}
{% block body %}
<h1>Voitures</h1>
<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Nom de la voiture</th>
            <th>Modele</th>
            <th>Moteur</th>
            <th>Image de la voiture</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for voiture in voitures %}
        <tr>
            <td>{{ voiture.id }}</td>
            <td>{{ voiture.nomVoiture }}</td>
            <td>{{ voiture.modele }}</td>
            <td>{{ voiture.moteur }}</td>
            <td>
                {% if voiture.imgVoiture %}
                <img class="logo-cadrage" src="{{ asset('web/img/imgVoiture/' ~ voiture.imgVoiture) }}" alt="{{ voiture.nomVoiture }}">
                {% else %}
                <div class="no-img">NO DATA</div>
                {% endif %}
            </td>
            <td>
                <a href="{{ path('app_voiture_show', {'id': voiture.id}) }}">show</a>
                {% if is_granted('ROLE_ADMIN') %}
                <a href="{{ path('app_voiture_edit', {'id': voiture.id}) }}">edit</a>
                {% endif %}
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="6">no records found</td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% if is_granted('ROLE_ADMIN') %}
    <a class="btn-create" href="{{ path('app_voiture_new') }}">+ Create new</a>
{% endif %}
{% endblock %}