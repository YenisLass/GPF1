{% extends 'base.html.twig' %}
{% block title %}Voiture{% endblock %}
{% block body %}
<h1>Voiture</h1>
<table class="table">
    <tbody>
        <tr>
            <th>Id</th>
            <td>{{ voiture.id }}</td>
        </tr>
        <tr>
            <th>NomVoiture</th>
            <td>{{ voiture.nomVoiture }}</td>
        </tr>
        <tr>
            <th>Modele</th>
            <td>{{ voiture.modele }}</td>
        </tr>
        <tr>
            <th>Moteur</th>
            <td>{{ voiture.moteur }}</td>
        </tr>
        <tr>
            <th>ImgVoiture</th>
            <td>
                {% if voiture.imgVoiture %}
                <img src="{{ asset('web/img/imgVoiture/' ~ voiture.imgVoiture) }}" alt="{{ voiture.nomVoiture }}">
                {% else %}
                <div class="no-img">NO DATA</div>
                {% endif %}
            </td>
        </tr>
    </tbody>
</table>
<div class="action-buttons">
    <a class="btn-back" href="{{ path('app_voiture_index') }}">← Back to list</a>
    {% if is_granted('ROLE_ADMIN') %}
    <a class="btn-edit" href="{{ path('app_voiture_edit', {'id': voiture.id}) }}">Edit</a>
    {{ include('voiture/_delete_form.html.twig') }}
    {% endif %}
</div>
{% endblock %}