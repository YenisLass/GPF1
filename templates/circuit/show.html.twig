{% extends 'base.html.twig' %}

{% block title %}Circuit{% endblock %}

{% block body %}
<h1>Circuit</h1>

<table class="table">
    <tbody>
        <tr>
            <th>Id</th>
            <td>{{ circuit.id }}</td>
        </tr>
        <tr>
            <th>NomCircuit</th>
            <td>{{ circuit.nomCircuit }}</td>
        </tr>
        <tr>
            <th>Lieu</th>
            <td>{{ circuit.lieu }}</td>
        </tr>
        <tr>
            <th>NbTour</th>
            <td>{{ circuit.nbTour }}</td>
        </tr>
        <tr>
            <th>DistanceCircuit</th>
            <td>{{ circuit.distanceCircuit }}</td>
        </tr>
    </tbody>
</table>

<div class="action-buttons">
    <a class="btn-back" href="{{ path('app_circuit_index') }}">← Back to list</a>
    {% if is_granted('ROLE_ADMIN') %}
    <a class="btn-edit" href="{{ path('app_circuit_edit', {'id': circuit.id}) }}">Edit</a>
    {{ include('circuit/_delete_form.html.twig') }}
    {% endif %}
</div>
{% endblock %}