{% extends 'base.html.twig' %}

{% block title %}Admin - Gestion des membres{% endblock %}

{% block body %}
<div style="padding: 2rem;">
    <h1>Gestion des membres</h1>

    {% for message in app.flashes('success') %}
        <div class="flash flash-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="flash flash-error">{{ message }}</div>
    {% endfor %}

    <table class="table" style="margin-top: 2rem;">
        <thead>
            <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Nom</th>
                <th>Prénom</th>
                <th>Email</th>
                <th>Rôle</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for membre in membres %}
            <tr>
                <td>{{ membre.id }}</td>
                <td>{{ membre.username }}</td>
                <td>{{ membre.nomMembre }}</td>
                <td>{{ membre.prenomMembre }}</td>
                <td>{{ membre.mailMembre }}</td>
                <td>
                    {% if 'ROLE_ADMIN' in membre.roles %}
                        <span class="badge-admin">ADMIN</span>
                    {% else %}
                        <span class="badge-user">USER</span>
                    {% endif %}
                </td>
                <td>
                    {% if membre != app.user %}
                        <form method="post" action="{{ path('app_admin_toggle_role', {'id': membre.id}) }}" style="display:inline;">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ membre.id) }}">
                            <button type="submit" class="btn-edit" style="width:fit-content; white-space:nowrap; font-size:0.75rem; padding: 6px 16px;">
                                {% if 'ROLE_ADMIN' in membre.roles %}
                                    → USER
                                {% else %}
                                    → ADMIN
                                {% endif %}
                            </button>
                        </form>
                        <form method="post" action="{{ path('app_admin_delete_membre', {'id': membre.id}) }}" style="display:inline;" onsubmit="return confirm('Supprimer ce membre ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ membre.id) }}">
                            <button type="submit" class="btn-delete" style="width:fit-content; white-space:nowrap; font-size:0.75rem; padding: 6px 16px;">Supprimer</button>
                        </form>
                    {% else %}
                        <span style="color: rgba(255,255,255,0.3); font-size: 0.8rem;">Vous</span>
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}